# ── 必填（至少填写一个 provider key）──────────────────────────────────────────

# GLM（智谱 AI）API Key
# 申请地址: https://open.bigmodel.cn
BIGMODEL_API_KEY=your_bigmodel_api_key_here

# Kimi for Coding API Key（与普通 Moonshot key 类型不同）
# KIMI_API_KEY=your_kimi_api_key_here

# Xiaomi MiMo API Key（如只填此项，会自动切换到 Mimo）
# 申请地址: https://platform.xiaomimimo.com
# MIMO_API_KEY=your_mimo_api_key_here

# MiniMax API Key（如只填此项，会自动切换到 MiniMax）
# 申请地址: https://platform.minimaxi.com
# MINIMAX_API_KEY=your_minimax_api_key_here

# ── 可选：选择 LLM Provider ────────────────────────────────────────────────────

# 显式指定使用的 provider：glm / kimi / mimo / minimax
# 不填时自动检测：Kimi > MiniMax > Mimo > GLM
# LLM_PROVIDER=glm

# ── 可选：GLM 配置 ─────────────────────────────────────────────────────────────

# 使用的模型，默认 glm-5；也可切换为 GLM-4.7 或 glm-5.1
# BIGMODEL_MODEL=glm-5

# API 地址，默认使用官方地址，一般不需要改
# BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# ── 可选：MiniMax 配置 ─────────────────────────────────────────────────────────

# 使用的模型，默认 MiniMax-M2.5
# Supported MiniMax text models:
# MiniMax-M2.7 / MiniMax-M2.7-highspeed /
# MiniMax-M2.5 / MiniMax-M2.5-highspeed
# MINIMAX_MODEL=MiniMax-M2.5

# API 地址，默认使用官方地址，一般不需要改
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# ── 可选：Mimo 配置 ────────────────────────────────────────────────────────────

# 使用的模型，默认 mimo-v2-pro
# Supported Mimo chat models:
# mimo-v2-pro / mimo-v2-flash / mimo-v2-omni
# MIMO_MODEL=mimo-v2-pro

# API 地址，默认使用官方普通 chat 兼容地址
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# 上下文预算估算值，默认 256000，可按账号实际可用上下文覆盖
# MIMO_CONTEXT_WINDOW_TOKENS=256000

# ── 可选：通用配置 ─────────────────────────────────────────────────────────────

# 单次请求超时（毫秒），默认无限制
# API_TIMEOUT_MS=60000

# HTTP 代理（国内访问外部 API 时使用）
# HTTP_PROXY=http://127.0.0.1:7890

# ── 可选：联网搜索 ──────────────────────────────────────────────────────────────

# 博查 AI 搜索 API Key —— 不填则禁用 web_search 工具
# 申请地址: https://open.bochaai.com
# BOCHA_API_KEY=sk-your_bocha_api_key_here

# ── 可选：启动时自动执行任务 ────────────────────────────────────────────────────

# 设置后，GoldBot 启动时会直接执行该任务，不等待用户输入
# GOLDBOT_TASK=整理当前目录并汇总文件信息
